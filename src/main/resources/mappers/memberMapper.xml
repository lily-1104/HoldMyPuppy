<?xml version="1.0" encoding="UTF-8"?>

<!DOCTYPE mapper
  PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
  "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.holdmypuppy.member.login.dao.MemberDAO">
	
	
		<!-- 회원 가입 -->
		
	<insert id="insertMember" parameterType="map">
	
		INSERT INTO
			`member`
		(
			`loginId`
			, `password`
			, `name`
			, `phoneNumber`
			, `nickname`
			, `memberCode`
			, `createdAt`
			, `updatedAt`
		)
		
		VALUES
		(
			#{loginId}
			, #{password}
			, #{name}
			, #{phoneNumber}
			, #{nickname}
			, #{memberCode}
			, now()
			, now()
		)
	
	</insert>

	
	
		<!-- 아이디 중복 확인 -->
	
	<select id="selectCountLoginId" parameterType="string" resultType="int">
	
		SELECT
			count(1)
		
		FROM
			`member`
		
		WHERE
			`loginId` = #{loginId}
	
	</select>
	
	
	
		<!-- 닉네임 중복 확인 -->
	
	<select id="selectCountLoginNickname" parameterType="string" resultType="int">  
	
		SELECT
			count(1)
		
		FROM
			`member`
		
		WHERE
			`nickname` = #{nickname}
			
	</select>
	
	
	
		<!--  로그인 API  -->
	
	<select id="selectMember" parameterType="map"
		resultType="com.holdmypuppy.member.login.model.Member">
		
		SELECT
			`id`
			, `loginId`
			, `password`
			, `name`
			, `phoneNumber`
			, `nickname`
			, `memberCode`
			, `createdAt`
			, `updatedAt`
			
		FROM
			`member`
		
		WHERE
			`loginId` = #{loginId}
			AND `password` = #{password}
		
	</select>
	
	
	
		<!-- id로 사용자 정보 조회 (댓글) -->
		
	<select id="selectMemberById" parameterType="int"
		resultType="com.holdmypuppy.member.login.model.Member">
		
		SELECT
			`id`
			, `loginId`
			, `password`
			, `name`
			, `phoneNumber`
			, `nickname`
			, `memberCode`
			, `createdAt`
			, `updatedAt`
			
		FROM
			`member`
			
		WHERE
			`id` = #{id}
	
	</select>
	
	
</mapper>