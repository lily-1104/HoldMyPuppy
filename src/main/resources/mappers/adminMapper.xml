<?xml version="1.0" encoding="UTF-8"?>

<!DOCTYPE mapper
  PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
  "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.holdmypuppy.admin.login.dao.AdminDAO">


		<!-- 관리자 회원가입 API -->
	
	<insert id="insertAdmin" parameterType="map">
	
		INSERT INTO
			`member`
		(
			`loginId`
			, `password`
			, `name`
			, `phoneNumber`
			, `nickname`
			, `memberCode`
			, `createdAt`
			, `updatedAt`
		)
		
		VALUES
		(
			#{loginId}
			, #{password}
			, #{name}
			, #{phoneNumber}
			, #{nickname}
			, #{memberCode}
			, now()
			, now()
		)
	
	</insert>
	
	
	
		<!-- 관리자 회원 가입 - 아이디 중복 확인 -->
	
	<select id="selectCountLoginId" parameterType="string" resultType="int">
	
		SELECT
			count(1)
		
		FROM
			`member`
		
		WHERE
			`loginId` = #{loginId}
	
	</select>
	
	
	
		<!-- 관리자 회원 가입 - 닉네임 중복 확인 -->
	
	<select id="selectCountLoginNickname" parameterType="string" resultType="int">
	
		SELECT
			count(1)
		
		FROM
			`member`
		
		WHERE
			`nickname` = #{nickname}
	
	</select>



		<!--  로그인 API  -->
	
	<select id="selectAdmin" parameterType="map"
		resultType="com.holdmypuppy.admin.login.model.Admin">
		
		SELECT
			`id`
			, `loginId`
			, `password`
			, `name`
			, `phoneNumber`
			, `nickname`
			, `memberCode`
			, `createdAt`
			, `updatedAt`
		
		FROM
			`member`
			
		WHERE
			`loginId` = #{loginId}
			AND `password` = #{password}
	
	</select>


</mapper>