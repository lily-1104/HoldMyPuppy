<?xml version="1.0" encoding="UTF-8"?>

<!DOCTYPE mapper
  PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
  "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.holdmypuppy.member.review.dao.ReviewDAO">


		<!-- 입양 후기 작성 게시글 업로드 API -->
	
	<insert id="addPost" parameterType="map">
	
		INSERT INTO
			`review`
		(
			`memberId`
			, `title`
			, `dogName`
			, `breed`
			, `file`
			, `content`
			, `createdAt`
			, `updatedAt`
		)
		
		VALUES
		(
			#{memberId}
			, #{title}
			, #{dogName}
			, #{breed}
			, #{imagePath}
			, #{content}
			, now()
			, now()
		)
			
	</insert>
	
	
	
		<!-- 입양 후기 리스트 -->
	
	<select id="selectReviewList" parameterType="int"
		resultType="com.holdmypuppy.member.review.model.Review">
	
		SELECT
			`memberId`
			, `title`
			, `dogName`
			, `breed`
			, `file`
			, `content`
			, `createdAt`
			, `updatedAt`
		
		FROM
			`review`
		
		ORDER BY
			`id` DESC
	
	</select>
	
	
	
	
	

</mapper>